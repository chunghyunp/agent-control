datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Task {
  id          String    @id
  title       String
  prompt      String?
  status      String    @default("pending")
  result      String?
  pipeline    String?
  repoTarget  String?
  branch      String?
  completedAt DateTime?
  totalCost   Float     @default(0)
  agentCount  Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  logs        Log[]
  costs       AgentCost[]
  files       TaskFile[]
}

model Log {
  id        Int      @id @default(autoincrement())
  taskId    String
  agent     String
  type      String
  message   String
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model AgentCost {
  id           Int    @id @default(autoincrement())
  taskId       String
  agent        String
  inputTokens  Int    @default(0)
  outputTokens Int    @default(0)
  costUsd      Float  @default(0)
  task         Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  @@unique([taskId, agent])
}

model TaskFile {
  id        Int      @id @default(autoincrement())
  taskId    String
  path      String
  content   String
  githubUrl String?
  agentName String?
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  @@unique([taskId, path])
}

model Settings {
  id        String   @id @default("default")
  data      String   // AES-256-GCM encrypted JSON
  updatedAt DateTime @updatedAt
}
