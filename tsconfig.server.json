{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "lib": ["ES2020"],
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./.server"
  },
  "include": ["server.ts", "src/lib/**/*.ts"],
  "exclude": ["node_modules", "src/app/**/*.ts", "src/app/**/*.tsx"]
}
